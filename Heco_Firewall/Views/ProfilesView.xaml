<UserControl x:Class="Heco_Firewall.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heco_Firewall.Converters"
             xmlns:prof="clr-namespace:Heco.Common.Services.Profiles">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <Style x:Key="FingerprintItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushBgHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="0,0,20,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Application Profiles" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,16" />

            <!-- Toolbar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="↻ Refresh" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Profiles.RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="Edit" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Profiles.EditProfileCommand}" Margin="0,0,6,0" />
                    <Button Content="＋ Auto-Generate" Style="{StaticResource BtnPrimary}"
                            Command="{Binding Profiles.AutoGenerateCommand}" Margin="0,0,6,0" />
                    <Button Content="Delete" Style="{StaticResource BtnDanger}"
                            Command="{Binding Profiles.DeleteProfileCommand}" />
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                <TextBlock Text="{Binding Profiles.StatusText}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
            </Border>

            <!-- Profile Editor Panel -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16"
                    Visibility="{Binding Profiles.IsEditing, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Profile Editor" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Profiles.EditName}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Fingerprints" VerticalAlignment="Top"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                            <ListBox ItemsSource="{Binding Profiles.EditingFingerprints}"
                                     ItemContainerStyle="{StaticResource FingerprintItemStyle}"
                                     MaxHeight="120" Background="{StaticResource BrushBgMid}"
                                     BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                                     SelectionMode="Single" Margin="0,0,0,4">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="prof:ProfileFingerprint">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Type}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                                            <TextBlock Grid.Column="1" Text="{Binding Operator}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                                            <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{StaticResource BrushTextPrimary}" FontSize="12" />
                                            <Button Grid.Column="3" Content="✕" FontSize="10"
                                                    Background="Transparent" Foreground="{StaticResource BrushRed}"
                                                    BorderThickness="0" Padding="4,0" Cursor="Hand"
                                                    Command="{Binding DataContext.Profiles.RemoveFingerprintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding Profiles.AvailableFingerprintTypes}"
                                          SelectedItem="{Binding Profiles.NewFingerprintType}"
                                          FontSize="11" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding Profiles.NewFingerprintValue}"
                                         FontSize="11" Margin="0,0,4,0" />
                                <Button Grid.Column="2" Content="＋ Add" FontSize="11"
                                        Style="{StaticResource BtnSecondary}" Padding="8,2"
                                        Command="{Binding Profiles.AddFingerprintCommand}" />
                            </Grid>
                        </StackPanel>

                        <!-- Action Override -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Actions" VerticalAlignment="Top"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                            <CheckBox Content="Inherit global settings (no override)"
                                      IsChecked="{Binding Profiles.EditInheritActions}"
                                      Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,4" />
                            <Grid IsEnabled="{Binding Profiles.EditInheritActions, Converter={StaticResource InverseBool}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Content="Allow Out" Margin="0,0,12,0"
                                          IsChecked="{Binding Profiles.EditAllowOut}"
                                          Foreground="{StaticResource BrushGreen}" />
                                <CheckBox Grid.Column="1" Content="Allow In" Margin="0,0,12,0"
                                          IsChecked="{Binding Profiles.EditAllowIn}"
                                          Foreground="{StaticResource BrushGreen}" />
                                <CheckBox Grid.Column="2" Content="Block Out" Margin="0,0,12,0"
                                          IsChecked="{Binding Profiles.EditBlockOut}"
                                          Foreground="{StaticResource BrushRed}" />
                                <CheckBox Grid.Column="3" Content="Block In"
                                          IsChecked="{Binding Profiles.EditBlockIn}"
                                          Foreground="{StaticResource BrushRed}" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,8" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource BtnDanger}"
                                Command="{Binding Profiles.DiscardEditCommand}" Margin="0,0,8,0" />
                        <Button Content="Save Profile" Style="{StaticResource BtnPrimary}"
                                Command="{Binding Profiles.SaveProfileCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Profile DataGrid -->
            <Grid Margin="0,0,0,12">
                <Border x:Name="TableMask" Background="White" CornerRadius="8" />
                <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="0">
                    <Border.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=TableMask}"/>
                    </Border.OpacityMask>
                    <Grid SnapsToDevicePixels="True">
                        <TextBlock Text="No application profiles created. Click '＋ Auto-Generate' to create them."
                                   Foreground="{StaticResource BrushTextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" IsHitTestVisible="False"
                                   Visibility="{Binding Profiles.TotalProfiles, Converter={StaticResource IsEmpty}}" />
                        <DataGrid ItemsSource="{Binding Profiles.Profiles}"
                                  SelectedItem="{Binding Profiles.SelectedProfile}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  RowHeight="32" AlternatingRowBackground="{StaticResource BrushBgLight}"
                                  MaxWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Profile Name" Binding="{Binding Name}" Width="Auto" />
                                <DataGridCheckBoxColumn Header="Special" Binding="{Binding IsSpecial}" Width="Auto" />
                                <DataGridCheckBoxColumn Header="Auto" Binding="{Binding IsAutoGenerated}" Width="Auto" />
                                <DataGridTextColumn Header="Fingerprints" Width="Auto">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Fingerprints.Count" StringFormat="{}{0}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Action Override" Binding="{Binding ActionOverride, Converter={x:Static conv:NetworkActionSettingsConverter.Default}}" Width="Auto" />
                                <DataGridTextColumn Header="Hits" Binding="{Binding HitCount}" Width="Auto" />
                                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
