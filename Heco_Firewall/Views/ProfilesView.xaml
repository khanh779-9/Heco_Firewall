<UserControl x:Class="Heco_Firewall.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heco_Firewall.Converters"
             xmlns:prof="clr-namespace:Heco.Common.Services.Profiles">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <Style x:Key="FingerprintItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BrushBgHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Margin="0,0,20,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Application Profiles" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,16" />

            <!-- Toolbar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="↻ Refresh" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Profiles.RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="Edit" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Profiles.EditProfileCommand}" Margin="0,0,6,0" />
                    <Button Content="＋ Auto-Generate" Style="{StaticResource BtnPrimary}"
                            Command="{Binding Profiles.AutoGenerateCommand}" Margin="0,0,6,0" />
                    <Button Content="Delete" Style="{StaticResource BtnDanger}"
                            Command="{Binding Profiles.DeleteProfileCommand}" />
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                <TextBlock Text="{Binding Profiles.StatusText}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
            </Border>


            <!-- Profile DataGrid -->
            <Grid Margin="0,0,0,12">
                <Border x:Name="TableMask" Background="White" CornerRadius="8" />
                <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="0">
                    <Border.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=TableMask}"/>
                    </Border.OpacityMask>
                    <Grid SnapsToDevicePixels="True">
                        <TextBlock Text="No application profiles created. Click '＋ Auto-Generate' to create them."
                                   Foreground="{StaticResource BrushTextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" IsHitTestVisible="False"
                                   Visibility="{Binding Profiles.TotalProfiles, Converter={StaticResource IsEmpty}}" />
                        <DataGrid ItemsSource="{Binding Profiles.Profiles}"
                                  SelectedItem="{Binding Profiles.SelectedProfile}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  RowHeight="32" AlternatingRowBackground="{StaticResource BrushBgLight}"
                                  MaxWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Profile Name" Binding="{Binding Name}" Width="Auto" />
                                <DataGridCheckBoxColumn Header="Special" Binding="{Binding IsSpecial}" Width="Auto" />
                                <DataGridCheckBoxColumn Header="Auto" Binding="{Binding IsAutoGenerated}" Width="Auto" />
                                <DataGridTextColumn Header="Fingerprints" Width="Auto">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Fingerprints.Count" StringFormat="{}{0}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Action Override" Binding="{Binding ActionOverride, Converter={x:Static conv:NetworkActionSettingsConverter.Default}}" Width="Auto" />
                                <DataGridTextColumn Header="Hits" Binding="{Binding HitCount}" Width="Auto" />
                                <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd}}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
