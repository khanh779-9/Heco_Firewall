<UserControl x:Class="Heco_Firewall.Views.RulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heco_Firewall.Converters">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Rule List -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Grid.Row="0" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="＋ Add Rule" Style="{StaticResource BtnPrimary}"
                            Command="{Binding Rules.AddRuleCommand}" Margin="0,0,6,0" />
                    <Separator Width="1" Height="24" Margin="0,0,6,0" Background="{StaticResource BrushBorderLight}" />
                    <Button Content="Edit" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Rules.EditRuleCommand}" Margin="0,0,6,0" />
                    <Button Content="Delete Selected" Style="{StaticResource BtnDanger}"
                            Command="{Binding Rules.DeleteSelectedCommand}" Margin="0,0,6,0" />
                    <Button Content="⇄ Toggle Selected" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Rules.ToggleSelectedCommand}" />
                </StackPanel>
            </Border>

            <!-- Summary bar -->
            <Border Grid.Row="1" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{StaticResource BrushTextSecondary}" FontSize="11">
                        <Run Text="{Binding Rules.TotalRules, Mode=OneWay}" />
                        <Run Text=" rules ·" />
                        <Run Text="{Binding Rules.ActiveRules, Mode=OneWay}" />
                        <Run Text=" active ·" />
                        <Run Text="{Binding Rules.BlockRules, Mode=OneWay}" />
                        <Run Text=" blocking ·" />
                        <Run Text="{Binding Rules.PermitRules, Mode=OneWay}" />
                        <Run Text=" permitting" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- DataGrid -->
            <Grid Grid.Row="2">
                <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="8">
                    <Grid ClipToBounds="True">
                        <TextBlock Text="No firewall rules yet. Click '＋ Add Rule' to create one."
                                   Foreground="{StaticResource BrushTextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" IsHitTestVisible="False"
                                   Visibility="{Binding Rules.TotalRules, Converter={StaticResource IsEmpty}}" />
                        <DataGrid ItemsSource="{Binding Rules.Rules}"
                                  Background="Transparent" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <!-- Checkbox column -->
                                <DataGridTemplateColumn Width="36">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding DataContext.Rules.SelectAll, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridCheckBoxColumn Header="On" Binding="{Binding IsEnabled}" Width="Auto" />

                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                            <Setter Property="VerticalAlignment" Value="Center" />
                                            <Setter Property="ToolTip" Value="{Binding Name}" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Action" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Action}" FontWeight="Bold"
                                                       Foreground="{Binding Action, Converter={StaticResource ActionColor}}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="Auto" />

                                <DataGridTextColumn Header="Proto" Width="Auto">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="Protocol" Converter="{StaticResource ProtocolText}" />
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>

                                <!-- Local Address:Port combined -->
                                <DataGridTemplateColumn Header="Local" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource BrushTextPrimary}" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}:{1}">
                                                        <Binding Path="LocalAddress" TargetNullValue="*" FallbackValue="*" />
                                                        <Binding Path="LocalPort" TargetNullValue="*" FallbackValue="*" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                                <TextBlock.ToolTip>
                                                    <MultiBinding StringFormat="Address: {0}&#x0a;Port: {1}">
                                                        <Binding Path="LocalAddress" TargetNullValue="Any" FallbackValue="Any" />
                                                        <Binding Path="LocalPort" TargetNullValue="Any" FallbackValue="Any" />
                                                    </MultiBinding>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Remote Address:Port combined -->
                                <DataGridTemplateColumn Header="Remote" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource BrushTextPrimary}" FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}:{1}">
                                                        <Binding Path="RemoteAddress" TargetNullValue="*" FallbackValue="*" />
                                                        <Binding Path="RemotePort" TargetNullValue="*" FallbackValue="*" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                                <TextBlock.ToolTip>
                                                    <MultiBinding StringFormat="Address: {0}&#x0a;Port: {1}">
                                                        <Binding Path="RemoteAddress" TargetNullValue="Any" FallbackValue="Any" />
                                                        <Binding Path="RemotePort" TargetNullValue="Any" FallbackValue="Any" />
                                                    </MultiBinding>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- App (show filename only, full path in tooltip) -->
                                <DataGridTemplateColumn Header="Application" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ApplicationPath, Converter={StaticResource FileNameOnly}}"
                                                       ToolTip="{Binding ApplicationPath}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource BrushTextPrimary}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Hits" Binding="{Binding HitCount}" Width="Auto" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Rule Editor Panel -->
        <Border Grid.Column="1" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="1" CornerRadius="8" Padding="16" MinWidth="360" MaxWidth="450"
                Visibility="{Binding Rules.IsEditing, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Rule Editor" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" />

                <Label Content="Name" />
                <TextBox Text="{Binding Rules.EditingRule.Name}" />

                <Label Content="Action" />
                <ComboBox ItemsSource="{Binding Rules.AvailableActions}"
                          SelectedItem="{Binding Rules.EditingRule.Action}" />

                <Label Content="Direction" />
                <ComboBox ItemsSource="{Binding Rules.AvailableDirections}"
                          SelectedItem="{Binding Rules.EditingRule.Direction}" />

                <Label Content="Protocol" />
                <ComboBox ItemsSource="{Binding Rules.AvailableProtocols}"
                          SelectedItem="{Binding Rules.EditingRule.Protocol}" />

                <Label Content="Address Family" />
                <ComboBox ItemsSource="{Binding Rules.AvailableAddressFamilies}"
                          SelectedItem="{Binding Rules.EditingRule.AddressFamily}" />

                <Label Content="Local Address (CIDR)" />
                <TextBox Text="{Binding Rules.EditingRule.LocalAddress}" />

                <Label Content="Local Port" />
                <TextBox Text="{Binding Rules.EditingRule.LocalPort, Converter={x:Static conv:NullablePortConverter.Default}}" />

                <Label Content="Remote Address (CIDR)" />
                <TextBox Text="{Binding Rules.EditingRule.RemoteAddress}" />

                <Label Content="Remote Port" />
                <TextBox Text="{Binding Rules.EditingRule.RemotePort, Converter={x:Static conv:NullablePortConverter.Default}}" />

                <Label Content="Application Path" />
                <TextBox Text="{Binding Rules.EditingRule.ApplicationPath}" />

                <Separator Margin="0,8" Background="{StaticResource BrushBorderLight}" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Discard" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Rules.DiscardCommand}" Margin="0,0,8,0" />
                    <Button Content="Save" Style="{StaticResource BtnPrimary}"
                            Command="{Binding Rules.SaveCommand}" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
