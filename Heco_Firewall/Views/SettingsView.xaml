<UserControl x:Class="Heco_Firewall.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer Margin="0,0,20,0">
        <StackPanel>
            <TextBlock Text="Application Settings" FontSize="15" FontWeight="SemiBold"
                        Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,16" />

            <!-- General -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="General" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Minimize to tray" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.MinimizeToTray}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Show block notifications" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.ShowNotifications}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Auto-apply rules on connect" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.AutoApplyRules}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Interactive Connection Mode" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.InteractiveMode}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Auto-start with Windows" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.StartWithWindows}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Refresh interval (ms)" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <TextBox Grid.Column="1" Text="{Binding Settings.AppSettings.RefreshInterval}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Connection cache size" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <TextBox Grid.Column="1" Text="{Binding Settings.AppSettings.ConnectionCacheSize}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Self-Defense -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Self-Defense" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center" />
                        <Border Grid.Column="1" Background="{StaticResource BrushDanger}" CornerRadius="4"
                                Padding="6,2" Margin="8,0,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Kernel Driver" FontSize="10" FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <TextBlock Text="Protects the Heco Firewall process from being terminated or tampered with by other processes. Uses a kernel driver (ObRegisterCallbacks) to block dangerous handle operations."
                               TextWrapping="Wrap" Foreground="{StaticResource BrushTextSecondary}" FontSize="12"
                               Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Enable Self-Defense" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AppSettings.EnableSelfDefense}"
                                  IsEnabled="{Binding Settings.IsSelfDefenseBusy, Converter={StaticResource InverseBool}}" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Protection Level" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding Settings.AppSettings.SelfDefenseLevel}"
                                  IsEnabled="{Binding Settings.AppSettings.EnableSelfDefense}">
                            <ComboBoxItem Content="Basic (prevent kill)" />
                            <ComboBoxItem Content="Standard (+ protect memory)" />
                            <ComboBoxItem Content="Hardened (full isolation)" />
                        </ComboBox>
                    </Grid>

                    <!-- Status -->
                    <Border Background="{StaticResource BrushBgSurface}" CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding Settings.SelfDefenseStatus, Converter={StaticResource StatusColorConverter}}" />
                            <TextBlock Grid.Column="1" Text="{Binding Settings.SelfDefenseStatus}"
                                       Foreground="{StaticResource BrushTextSecondary}" FontSize="12"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="{Binding Settings.AppSettings.EnableSelfDefense, Converter={StaticResource BoolToToggleText}}"
                                    Command="{Binding Settings.ToggleSelfDefenseCommand}"
                                    IsEnabled="{Binding Settings.IsSelfDefenseBusy, Converter={StaticResource InverseBool}}"
                                    Padding="12,4" FontSize="12" MinWidth="80" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Note: Requires Administrator privileges. The driver uses documented Windows APIs (ObRegisterCallbacks) and is safe under PatchGuard."
                               TextWrapping="Wrap" Foreground="{StaticResource BrushTextTertiary}" FontSize="11"
                               Margin="0,12,0,0" />
                </StackPanel>
            </Border>

            <!-- GeoIP -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,12">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="GeoIP Databases" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center" />
                        <Border Grid.Column="1" Background="{StaticResource BrushAccent}" CornerRadius="4"
                                Padding="6,2" Margin="8,0,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="MaxMind" FontSize="10" FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </Grid>

                    <TextBlock Text="GeoLite2 databases provide IP geolocation (country, city) and ASN (autonomous system number) lookup. Used to enrich connection details with geographic information."
                               TextWrapping="Wrap" Foreground="{StaticResource BrushTextSecondary}" FontSize="12"
                               Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Path" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" />
                        <TextBlock Grid.Column="1" Text="{Binding Settings.GeoIpPath}"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Border Background="{StaticResource BrushBgSurface}" CornerRadius="4" Padding="12,8" Margin="0,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding Settings.GeoIpFilesExist, Converter={StaticResource BoolToStatusColorConverter}}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Settings.GeoIpFilesExist, Converter={StaticResource BoolToGeoIpStatusConverter}}"
                                       Foreground="{StaticResource BrushTextSecondary}" FontSize="12"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="2" Content="Download"
                                     Command="{Binding Settings.OpenGeoIpDownloadCommand}"
                                     Padding="12,4" FontSize="12" MinWidth="80" Margin="0,0,8,0" />
                            <Button Grid.Column="3" Content="MMDB Viewer"
                                     Command="{Binding Settings.OpenMmdbViewerCommand}"
                                     Padding="12,4" FontSize="12" MinWidth="80" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,20">
                <Button Content="Save Settings" Style="{StaticResource BtnPrimary}"
                        Command="{Binding Settings.SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
