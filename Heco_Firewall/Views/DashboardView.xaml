<UserControl x:Class="Heco_Firewall.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <UserControl.Resources>
        <!-- Stats Card Template -->
        <DataTemplate x:Key="StatsCard">
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8"
                    Padding="16,12" Margin="4">
                <StackPanel>
                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Text="{Binding Value}" Foreground="{StaticResource BrushTextPrimary}" FontSize="28" FontWeight="Light"
                               Margin="0,4,0,0" />
                    <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer Margin="0,0,20,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel>
        <!-- Status Shield -->
        <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="10" Padding="24,20" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- Shield icon: green when active, gray when disabled, red when error -->
                <Viewbox Width="48" Height="48" Margin="0,0,16,0">
                    <Canvas Width="24" Height="28">
                        <Path x:Name="ShieldPath" Canvas.Top="2" StrokeThickness="1.5">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEngineOpen}" Value="True">
                                            <Setter Property="Data" Value="M12,1 L22,5 L22,12 C22,18 18,24 12,27 C6,24 2,18 2,12 L2,5 Z"/>
                                            <Setter Property="Fill" Value="#22C55E"/>
                                            <Setter Property="Stroke" Value="#16A34A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEngineOpen}" Value="False">
                                            <Setter Property="Data" Value="M12,1 L22,5 L22,12 C22,18 18,24 12,27 C6,24 2,18 2,12 L2,5 Z"/>
                                            <Setter Property="Fill" Value="#9CA3AF"/>
                                            <Setter Property="Stroke" Value="#6B7280"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <!-- Checkmark when active -->
                        <Path x:Name="StatusIcon" Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" Canvas.Top="2">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEngineOpen}" Value="True">
                                            <Setter Property="Data" Value="M7,14 L11,18 L17,10"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Canvas>
                </Viewbox>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEngineOpen}" Value="True">
                                        <Setter Property="Text" Value="Firewall Protected"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEngineOpen}" Value="False">
                                        <Setter Property="Text" Value="Firewall Disabled"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEngineOpen}" Value="True">
                                        <Setter Property="Text" Value="All connections are being monitored and filtered"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsEngineOpen}" Value="False">
                                        <Setter Property="Text" Value="Protection is turned off — no filtering active"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Text="Overview" FontSize="13" Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,12" />

        <!-- Stats row -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="4">
                <StackPanel>
                    <TextBlock Text="Total Rules" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Text="{Binding Rules.TotalRules}" Foreground="{StaticResource BrushBlue}"
                               FontSize="32" FontWeight="Light" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="4">
                <StackPanel>
                    <TextBlock Text="Active (Block)" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Foreground="{StaticResource BrushRed}" FontSize="32" FontWeight="Light" Margin="0,4,0,0">
                        <Run Text="{Binding Rules.BlockRules, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding Rules.TotalRules, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="4">
                <StackPanel>
                    <TextBlock Text="Blocked Today" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Text="{Binding BlockedConnectionsToday}" Foreground="{StaticResource BrushRed}"
                               FontSize="32" FontWeight="Light" Margin="0,4,0,0" />
                    <TextBlock Text="by verdict engine" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="4">
                <StackPanel>
                    <TextBlock Text="Engine" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource BrushTextPrimary}"
                               FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="4">
                <StackPanel>
                    <TextBlock Text="Live Connections" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                    <TextBlock Text="{Binding Connections.TotalConnections}" Foreground="{StaticResource BrushGreen}"
                               FontSize="32" FontWeight="Light" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Quick actions -->
        <TextBlock Text="Actions" FontSize="13" Foreground="{StaticResource BrushTextSecondary}" Margin="0,24,0,8" />
        <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                CornerRadius="8" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Firewall Protection" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <CheckBox Style="{StaticResource ToggleSwitchStyle}"
                              IsChecked="{Binding IsEngineOpen, Mode=OneWay}"
                              Command="{Binding ToggleEngineCommand}"
                              VerticalAlignment="Center"
                              ToolTip="Enable/Disable firewall protection and connection monitoring"/>
                </StackPanel>
                <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource BrushTextSecondary}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEngineOpen}" Value="True">
                                    <Setter Property="Text" Value="Active — monitoring all connections"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushGreen}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsEngineOpen}" Value="False">
                                    <Setter Property="Text" Value="Disabled"/>
                                    <Setter Property="Foreground" Value="{StaticResource BrushRed}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Service Modules -->
        <TextBlock Text="Service Modules" FontSize="13" Foreground="{StaticResource BrushTextSecondary}" Margin="0,24,0,8" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="👤" FontSize="20" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Profiles" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                        <TextBlock Foreground="{StaticResource BrushBlue}" FontSize="22" FontWeight="Light" Margin="0,4,0,0">
                            <Run Text="{Binding Profiles.TotalProfiles, Mode=OneWay}" /><Run Text=" total" />
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource BrushTextSecondary}" FontSize="11" Margin="0,4,0,0">
                            <Run Text="{Binding Profiles.AutoGeneratedCount, Mode=OneWay}" /><Run Text=" auto · " />
                            <Run Text="{Binding Profiles.TotalHits, Mode=OneWay}" /><Run Text=" hits" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="1" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📋" FontSize="20" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Blocklists" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                        <TextBlock Foreground="{StaticResource BrushBlue}" FontSize="22" FontWeight="Light" Margin="0,4,0,0">
                            <Run Text="{Binding Blocklists.TotalEntries, Mode=OneWay, StringFormat={}{0:N0}}" /><Run Text=" entries" />
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource BrushTextSecondary}" FontSize="11" Margin="0,4,0,0">
                            <Run Text="{Binding Blocklists.OnlineCount, Mode=OneWay}" /><Run Text=" online · " />
                            <Run Text="{Binding Blocklists.OfflineCount, Mode=OneWay}" /><Run Text=" offline" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1" CornerRadius="8" Padding="16,14" Margin="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔄" FontSize="20" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="Activity" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
                        <TextBlock Foreground="{StaticResource BrushBlue}" FontSize="22" FontWeight="Light" Margin="0,4,0,0">
                            <Run Text="{Binding Activity.BlockEventCount, Mode=OneWay}" /><Run Text=" blocked" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </StackPanel>
    </ScrollViewer>
</UserControl>
