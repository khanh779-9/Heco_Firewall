<UserControl x:Class="Heco_Firewall.Views.BlocklistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Heco_Firewall.Converters">

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.0" To="1.0" Duration="0:0:0.25"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <ScrollViewer Margin="0,0,20,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Blocklists" FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,16" />

            <!-- Toolbar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <Button Content="＋ Add" Style="{StaticResource BtnPrimary}"
                            Command="{Binding Blocklists.BeginAddCommand}" Margin="0,0,6,0" />
                    <Button Content="↻ Refresh" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Blocklists.RefreshCommand}" Margin="0,0,6,0" />
                    <Button Content="⟳ Update All" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Blocklists.UpdateAllCommand}" Margin="0,0,6,0" />
                    <Button Content="⟳ Update Selected" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Blocklists.UpdateSelectedCommand}" Margin="0,0,6,0" />
                    <Button Content="Edit" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Blocklists.BeginEditCommand}" Margin="0,0,6,0" />
                    <Button Content="Entries" Style="{StaticResource BtnSecondary}"
                            Command="{Binding Blocklists.ViewEntriesCommand}" Margin="0,0,6,0" />
                    <Button Content="Remove" Style="{StaticResource BtnDanger}"
                            Command="{Binding Blocklists.RemoveCommand}" />
                </StackPanel>
            </Border>

            <!-- Edit Blocklist Editor Panel -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16"
                    Visibility="{Binding Blocklists.IsEditing, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Edit Blocklist" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Blocklists.EditName}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Content Type" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding Blocklists.AvailableContentTypes}"
                                  SelectedItem="{Binding Blocklists.EditContentType}"
                                  Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="URL (online)" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Blocklists.EditUrl}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Enabled" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <CheckBox Grid.Row="3" Grid.Column="1" IsChecked="{Binding Blocklists.EditIsEnabled}" Margin="0,0,0,8" />
                    </Grid>

                    <Separator Margin="0,8" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Save" Style="{StaticResource BtnPrimary}"
                                Command="{Binding Blocklists.SaveEditCommand}" Margin="0,0,8,0" />
                        <Button Content="Cancel" Style="{StaticResource BtnDanger}"
                                Command="{Binding Blocklists.CancelEditCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="6" Padding="12,8" Margin="0,0,0,8">
                <TextBlock Text="{Binding Blocklists.StatusText}" Foreground="{StaticResource BrushTextSecondary}" FontSize="11" />
            </Border>

            <!-- Add Blocklist Editor Panel -->
            <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="16"
                    Visibility="{Binding Blocklists.IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Add Blocklist" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Blocklists.NewName}" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Content Type" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <ComboBox Grid.Row="1" Grid.Column="1"
                                  ItemsSource="{Binding Blocklists.AvailableContentTypes}"
                                  SelectedItem="{Binding Blocklists.SelectedContentType}"
                                  Margin="0,0,0,8" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="URL (online)" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Blocklists.NewUrl}"
                                 ToolTip="Leave empty for offline file" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="File (offline)" VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Foreground="{StaticResource BrushTextSecondary}" FontSize="11"
                                   Text="Click 'Browse File' below to select a local file" Margin="0,0,0,8" />
                    </Grid>

                    <Separator Margin="0,8" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Browse File" Style="{StaticResource BtnSecondary}"
                                Command="{Binding Blocklists.AddOfflineCommand}" Margin="0,0,8,0" />
                        <Button Content="Add Online URL" Style="{StaticResource BtnPrimary}"
                                Command="{Binding Blocklists.AddOnlineCommand}" Margin="0,0,8,0" />
                        <Button Content="Cancel" Style="{StaticResource BtnDanger}"
                                Command="{Binding Blocklists.CancelAddCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Blocklist DataGrid -->
            <Grid Margin="0,0,0,12">
                <Border x:Name="TableMask" Background="White" CornerRadius="8" />
                <Border Background="{StaticResource BrushBgCard}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                        CornerRadius="8" Padding="0">
                    <Border.OpacityMask>
                        <VisualBrush Visual="{Binding ElementName=TableMask}"/>
                    </Border.OpacityMask>
                    <Grid SnapsToDevicePixels="True">
                        <TextBlock Text="No blocklists configured. Click '＋ Add' to add one."
                                   Foreground="{StaticResource BrushTextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" IsHitTestVisible="False"
                                   Visibility="{Binding Blocklists.Blocklists.Count, Converter={StaticResource IsEmpty}}" />
                        <DataGrid ItemsSource="{Binding Blocklists.Blocklists}"
                                  SelectedItem="{Binding Blocklists.SelectedBlocklist}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" BorderThickness="0"
                                  RowHeight="32" AlternatingRowBackground="{StaticResource BrushBgLight}"
                                  MaxWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="Auto" />
                            <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding IsEnabled}" Width="Auto" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source, Converter={x:Static conv:BlocklistSourceConverter.Default}}" Width="Auto" />
                            <DataGridTextColumn Header="Type" Binding="{Binding ContentType, Converter={x:Static conv:BlocklistContentTypeConverter.Default}}" Width="Auto" />
                            <DataGridTextColumn Header="Entries" Binding="{Binding EntryCount}" Width="Auto" />
                            <DataGridTextColumn Header="URL / Path" Binding="{Binding Url}" Width="Auto" />
                            <DataGridTextColumn Header="Last Updated" Width="Auto">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="LastUpdated" StringFormat="{}{0:yyyy-MM-dd HH:mm}" />
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
