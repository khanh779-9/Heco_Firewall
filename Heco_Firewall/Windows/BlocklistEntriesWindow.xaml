<win:BaseWindow x:Class="Heco_Firewall.Windows.BlocklistEntriesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:win="clr-namespace:Heco_Firewall.Windows"
        Title="Blocklist Entries" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Style="{StaticResource HecoWindowStyle}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Title -->
            <RowDefinition Height="Auto" /> <!-- Search -->
            <RowDefinition Height="*" />    <!-- ListBox -->
            <RowDefinition Height="Auto" /> <!-- Add Entry -->
            <RowDefinition Height="Auto" /> <!-- Count -->
            <RowDefinition Height="Auto" /> <!-- Buttons -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TblTitle" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,12" Visibility="Collapsed" />

        <!-- Search Box -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtSearch" Grid.Column="0" 
                     Height="32"
                     Tag="Search entries..."
                     TextChanged="TxtSearch_TextChanged" />
            <Button x:Name="BtnClearSearch" Grid.Column="1" Content="Clear" Style="{StaticResource BtnSecondary}"
                    Click="ClearSearch_Click" Margin="8,0,0,0" Padding="12,0" Height="32" Visibility="Collapsed" />
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BrushBgCard}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8" Padding="0">
            <Grid>
                <TextBlock x:Name="TxtNoEntries" Text="No entries" Foreground="{StaticResource BrushTextMuted}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" IsHitTestVisible="False" Visibility="Collapsed" />
                <ListBox x:Name="EntriesList" Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Consolas" FontSize="12"
                         SelectionMode="Extended">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{StaticResource BrushTextPrimary}" Padding="4,2" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TxtNewEntry" Grid.Column="0"
                     Height="32"
                     Tag="Type a domain or IP here..."
                     ToolTip="Type a domain or IP then press Enter to add"
                     KeyDown="TxtNewEntry_KeyDown" />
            <Button Grid.Column="1" Content="Add" Style="{StaticResource BtnSecondary}"
                    Click="AddEntry_Click" Margin="8,0,0,0" Padding="12,8" />
        </Grid>

        <TextBlock Grid.Row="4" x:Name="TblCount" Foreground="{StaticResource BrushTextSecondary}"
                   FontSize="11" Margin="0,8,0,0" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Remove Selected" Style="{StaticResource BtnDanger}"
                    Click="RemoveSelected_Click" Margin="0,0,8,0" />
            <Button Content="Save" Style="{StaticResource BtnPrimary}"
                    Click="Save_Click" Margin="0,0,8,0" IsDefault="True" />
            <Button Content="Cancel" Style="{StaticResource BtnSecondary}"
                    Click="Cancel_Click" IsCancel="True" />
        </StackPanel>
    </Grid>
</win:BaseWindow>
