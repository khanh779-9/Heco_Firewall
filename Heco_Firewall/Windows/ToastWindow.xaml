<Window x:Class="Heco_Firewall.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast"
        Width="380" Height="Auto"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Top="0" Left="0"
        WindowStartupLocation="Manual">

    <Border x:Name="ToastBorder" CornerRadius="12" BorderThickness="1.5" Opacity="0">
        <Border.RenderTransform>
            <TranslateTransform X="60" Y="0"/>
        </Border.RenderTransform>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard x:Name="EnterStoryboard">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="0.0" To="1.0" Duration="0:0:0.35" DecelerationRatio="0.8"/>
                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                         From="60" To="0" Duration="0:0:0.45" DecelerationRatio="0.8"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.2"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Circle -->
            <Border x:Name="IconBorder" Width="40" Height="40" CornerRadius="20" Grid.Column="0" Margin="0,0,14,0"
                    VerticalAlignment="Top">
                <Path x:Name="IconPath" Fill="White" Width="20" Height="20" Stretch="Uniform"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,2"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="MessageText" FontSize="12.5"
                           Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"
                           MaxWidth="280" LineHeight="18" LineStackingStrategy="BlockLineHeight"/>
            </StackPanel>

            <!-- Close Button -->
            <Button x:Name="CloseBtn" Grid.Column="2" Content="✕" FontSize="11" FontWeight="SemiBold"
                    Style="{StaticResource BtnGhost}" Width="28" Height="28" Padding="0"
                    VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8,-2,0,0"
                    ToolTip="Dismiss" Click="CloseBtn_Click"/>
        </Grid>
    </Border>
</Window>
