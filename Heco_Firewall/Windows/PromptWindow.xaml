<Window x:Class="Heco_Firewall.Windows.PromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Firewall Alert"
        Height="Auto"
        Width="500"
        SizeToContent="Height"
        MinWidth="400"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="PromptBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="PromptBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.93" To="1.0" Duration="0:0:0.35" DecelerationRatio="0.8"/>
                    <DoubleAnimation Storyboard.TargetName="PromptBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.93" To="1.0" Duration="0:0:0.35" DecelerationRatio="0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="Transparent">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="8" Opacity="0.25"/>
        </Border.Effect>
        <Grid Margin="12">
            <Border x:Name="PromptBorder" Background="{StaticResource BrushBgCard}" CornerRadius="14" BorderBrush="{StaticResource BrushRed}" BorderThickness="2" Opacity="0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform/>
                </Border.RenderTransform>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Title & Warning Icon -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18" Background="{StaticResource BrushRed}" Margin="0,0,12,0">
                                <Path Data="M11,7h2v6h-2zm0,8h2v2h-2z" Fill="White" Width="18" Height="18" Stretch="Uniform"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Connection Alert" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushRed}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtCountdown" Grid.Column="2" Text="30s"
                                   Foreground="{StaticResource BrushTextSecondary}" FontSize="11"
                                   FontWeight="Medium" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="12,0,0,0"/>
                    </Grid>

                    <!-- Connection Details Card -->
                    <Border Grid.Row="1" Background="{StaticResource BrushBgMid}" CornerRadius="10"
                            BorderBrush="{StaticResource BrushBorderLight}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Process Icon -->
                            <Border Grid.Column="0" Width="52" Height="52" CornerRadius="10"
                                    Background="{StaticResource BrushBgLight}"
                                    VerticalAlignment="Top" Margin="0,0,16,0">
                                <Image x:Name="ProcessIcon" Width="36" Height="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                            </Border>

                            <!-- Details -->
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="TxtProcess" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"
                                           TextWrapping="Wrap"/>

                                <TextBlock x:Name="TxtPath" FontSize="11.5" Foreground="{StaticResource BrushTextSecondary}"
                                           Margin="0,0,0,10" TextWrapping="Wrap"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="85" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Destination:" Foreground="{StaticResource BrushTextSecondary}" FontSize="12.5" />
                                    <TextBlock x:Name="TxtDestination" Grid.Column="1" Foreground="{StaticResource BrushTextPrimary}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </Grid>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="85" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Protocol/Port:" Foreground="{StaticResource BrushTextSecondary}" FontSize="12.5" />
                                    <TextBlock x:Name="TxtPort" Grid.Column="1" Foreground="{StaticResource BrushTextPrimary}" FontSize="12.5" TextWrapping="Wrap"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Progress Bar for Countdown -->
<ProgressBar x:Name="ProgressTime" Grid.Row="2" Height="4"
                             Background="{StaticResource BrushBorder}" Foreground="{StaticResource BrushRed}"
                             BorderThickness="0" Maximum="30" Value="30" Margin="0,0,0,14"/>

                    <!-- Buttons -->
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Allow Once" Style="{StaticResource BtnSecondary}" Click="AllowOnce_Click"
                                Height="34" FontSize="12.5" FontWeight="Medium"/>
                        <Button Grid.Column="2" Content="Always Allow" Style="{StaticResource BtnPrimary}" Click="AlwaysAllow_Click"
                                Height="34" FontSize="12.5" FontWeight="Medium"/>
                        <Button Grid.Column="4" Content="Block Once" Style="{StaticResource BtnSecondary}" Click="BlockOnce_Click"
                                Height="34" FontSize="12.5" FontWeight="Medium"
                                Foreground="{StaticResource BrushRed}" BorderBrush="{StaticResource BrushRed}"/>
                        <Button Grid.Column="6" Content="Always Block" Style="{StaticResource BtnDanger}" Click="AlwaysBlock_Click"
                                Height="34" FontSize="12.5" FontWeight="Medium"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
