<Window x:Class="Heco_Firewall.Windows.MmdbViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MMDB Viewer"
        Width="520" Height="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="MainBorder" Background="{StaticResource BrushBgMid}" CornerRadius="8" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.18"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="6"
                        Background="{StaticResource BrushAccent}" Margin="0,0,12,0">
                    <TextBlock Text="M" FontSize="16" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White" />
                </Border>
                <TextBlock Grid.Column="1" Text="MMDB Viewer" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="✕" FontSize="12" Style="{StaticResource BtnGhost}"
                        Width="28" Height="28" Click="Close_Click" Padding="0" />
            </Grid>

            <!-- Loading Overlay -->
            <Border x:Name="LoadingOverlay" Grid.Row="1" Background="#CC1A1A1A"
                    CornerRadius="8" Visibility="Collapsed" Margin="0,16,0,0"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="20"
                            Background="{StaticResource BrushAccent}"
                            HorizontalAlignment="Center">
                        <Border.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" Angle="0"
                                             CenterX="20" CenterY="20"/>
                        </Border.RenderTransform>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsVisible" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="RenderTransform.Angle"
                                                        From="0" To="360"
                                                        Duration="0:0:01.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <TextBlock x:Name="TxtLoadingStatus" Text="Loading…"
                               Foreground="White" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Margin="0,16,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- File Selection -->
                    <Border Background="{StaticResource BrushBgCard}" CornerRadius="8"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Database File" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtDatabasePath" Grid.Column="0"
                                         Tag="Select an .mmdb file or use default path"
                                         FontSize="12" Height="32" VerticalContentAlignment="Center" />
                                <Button Grid.Column="1" Content="Browse" Style="{StaticResource BtnSecondary}"
                                        Padding="12,6" Margin="8,0,0,0" FontSize="12" Click="Browse_Click" />
                            </Grid>
                            <TextBlock x:Name="TxtDbStatus" Text=""
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- IP Lookup -->
                    <Border Background="{StaticResource BrushBgCard}" CornerRadius="8"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="IP Lookup" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtIpAddress" Grid.Column="0"
                                         Tag="Enter IP address (e.g. 8.8.8.8)"
                                         FontSize="13" Height="34" VerticalContentAlignment="Center"
                                         KeyDown="TxtIpAddress_KeyDown" />
                                <Button Grid.Column="1" Content="Lookup" Style="{StaticResource BtnPrimary}"
                                        Padding="16,6" Margin="8,0,0,0" FontSize="12"
                                        Click="Lookup_Click" x:Name="BtnLookup" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Results -->
                    <Border x:Name="ResultsCard" Background="{StaticResource BrushBgCard}" CornerRadius="8"
                            BorderBrush="{StaticResource BrushBorder}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Results" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,10" />
                            <ItemsControl x:Name="ResultsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Key}" 
                                                       Foreground="{StaticResource BrushTextSecondary}"
                                                       FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}"
                                                       Foreground="{StaticResource BrushTextPrimary}"
                                                       FontSize="12" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Error -->
                    <Border x:Name="ErrorCard" Background="{StaticResource BrushBgCard}" CornerRadius="8"
                            BorderBrush="{StaticResource BrushRed}" BorderThickness="1"
                            Padding="16" Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Error" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushRed}" Margin="0,0,0,6" />
                            <TextBlock x:Name="TxtError" Foreground="{StaticResource BrushTextSecondary}"
                                       FontSize="12" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
