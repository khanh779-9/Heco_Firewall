<Window x:Class="Heco_Firewall.Windows.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:win="clr-namespace:Heco_Firewall.Windows"
        Title=""
        Width="440" Height="Auto"
        SizeToContent="Height"
        MinWidth="380" MaxWidth="520"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="DialogBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.0" To="1.0" Duration="0:0:0.25"/>
                    <DoubleAnimation Storyboard.TargetName="DialogBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                     From="0.95" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
                    <DoubleAnimation Storyboard.TargetName="DialogBorder"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                     From="0.95" To="1.0" Duration="0:0:0.3" DecelerationRatio="0.8"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="Transparent">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="4" Opacity="0.18"/>
        </Border.Effect>
        <Grid Margin="12">
            <Border x:Name="DialogBorder" Background="{StaticResource BrushBgCard}" CornerRadius="12" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Opacity="0">
                <Border.RenderTransform>
                    <ScaleTransform CenterX="220" CenterY="100"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Title Bar with Icon & Close -->
                    <Grid Grid.Row="0" Margin="24,20,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon Circle -->
                        <Border x:Name="IconBorder" Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                Background="{StaticResource BrushAccent}" Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="IconText" FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White"/>
                        </Border>

                        <!-- Title -->
                        <TextBlock x:Name="TitleText" Grid.Column="1" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center"
                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>

                        <!-- Close button -->
                        <Button x:Name="CloseBtn" Grid.Column="2" Content="✕" FontSize="11" FontWeight="Bold"
                                Style="{StaticResource BtnGhost}" Width="28" Height="28" Click="CloseBtn_Click"
                                ToolTip="Close" Padding="0" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Message Content -->
                    <ScrollViewer Grid.Row="1" MaxHeight="260" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Margin="24,16,24,0">
                        <TextBlock x:Name="MessageText" TextWrapping="Wrap" FontSize="13.5"
                                   Foreground="{StaticResource BrushTextSecondary}"
                                   LineHeight="22" LineStackingStrategy="BlockLineHeight"/>
                    </ScrollViewer>

                    <!-- Separator -->
                    <Border Grid.Row="2" Height="1" Background="{StaticResource BrushBorderLight}"
                            Margin="24,20,24,0"/>

                    <!-- Action Buttons -->
                    <StackPanel x:Name="ButtonPanel" Grid.Row="3" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="24,16,24,20">
                        <!-- Buttons added dynamically in code-behind -->
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
